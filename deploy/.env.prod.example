# Copy into Coolify → colab-client2 project → Environment Variables.
# Do NOT commit real values.

# ---- Docker image (must match your GitHub org/repo path) ----
GITHUB_REPOSITORY=your-org/colab-client2
IMAGE_TAG=production-latest

# ---- Public domain (Traefik router) ----
APP_HOST=portal.yourdomain.com     # or portal.staging.yourdomain.com for staging

# Note: API_URL, APP_PUSHER_* are baked into the image at BUILD time by the CI
# pipeline (GitHub repo variables). They are NOT runtime env vars here.
#
# GitHub repo variables expected by the workflows:
#   API_URL                   e.g. https://api.yourdomain.com/v1
#   APP_PUSHER_APP_KEY        public Reverb app key
#   APP_PUSHER_HOST           e.g. ws.yourdomain.com
#   APP_PUSHER_AUTH_URL       e.g. https://api.yourdomain.com/v1/broadcasting/auth
#   + *_STAGING variants
